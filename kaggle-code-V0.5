chat_config = {
    "num_candidates": 8,          # Total candidates to choose from. (8 is a good balance)
    "parallel_candidates": 4,     # Try 4 at 0.8B and 2 at 4B.
                                  # Anything higher requires quantization, but setting to 1 will help.
